@model IEnumerable<FlightManagementSystem.Models.Flight>

@{
    ViewData["Title"] = "Search Flights";
}



<h2>Search Flights</h2>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <input type="text" name="source" class="form-control" placeholder="From" />
    </div>
    <div class="col-md-3">
        <input type="text" name="destination" class="form-control" placeholder="To" />
    </div>
    <div class="col-md-3">
        <input type="date" name="date" class="form-control" />
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-primary w-100">Search</button>
    </div>
</form>

@if (!Model.Any())
{
    <p>No flights found. Try different search criteria.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Flight No.</th>
                <th>From</th>
                <th>To</th>
                <th>Departure</th>
                <th>Arrival</th>
                <th>Capacity</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var flight in Model)
            {
                <tr>
                    <td>@flight.FlightNumber</td>
                    <td>@flight.Source</td>
                    <td>@flight.Destination</td>
                    <td>@flight.DepartureTime.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@flight.ArrivalTime.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@flight.Capacity</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@flight.FlightNumber" class="btn btn-sm btn-outline-primary">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}