@model FlightManagementSystem.Models.Flight
@{
    ViewData["Title"] = "Delete Flight";
}

<div class="alert alert-danger">
    <h4>⚠️ Delete Flight @Model.FlightNumber?</h4>
    <p>This action is permanent and cannot be undone. All associated reservations will also be affected.</p>
</div>

<div class="card shadow-sm" style="max-width:500px">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-5">Flight Number</dt>
            <dd class="col-sm-7">@Model.FlightNumber</dd>
            <dt class="col-sm-5">Route</dt>
            <dd class="col-sm-7">@Model.Source → @Model.Destination</dd>
            <dt class="col-sm-5">Departure</dt>
            <dd class="col-sm-7">@Model.DepartureTime.ToString("dd MMM yyyy HH:mm")</dd>
            <dt class="col-sm-5">Active Reservations</dt>
            <dd class="col-sm-7">@Model.BookedSeats</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3 d-flex gap-2">
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
