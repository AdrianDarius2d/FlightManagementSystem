@{
    ViewData["Title"] = "Book Flight";
    var flight = ViewBag.Flight as FlightManagementSystem.Models.Flight;
    var passenger = ViewBag.Passenger as FlightManagementSystem.Models.Passenger;
}

<h2>🎫 Book Flight @flight?.FlightNumber</h2>
<hr />

<div class="row">
    <div class="col-md-5">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white">Flight Summary</div>
            <div class="card-body">
                <p><strong>Route:</strong> @flight?.Source → @flight?.Destination</p>
                <p><strong>Departure:</strong> @flight?.DepartureTime.ToString("dddd, dd MMM yyyy HH:mm")</p>
                <p><strong>Arrival:</strong> @flight?.ArrivalTime.ToString("dddd, dd MMM yyyy HH:mm")</p>
                <p><strong>Aircraft:</strong> @flight?.AircraftType</p>
                <p><strong>Available Seats:</strong>
                    <span class="badge bg-success">@flight?.AvailableSeats</span>
                </p>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-secondary text-white">Passenger</div>
            <div class="card-body">
                <p><strong>Name:</strong> @passenger?.FullName</p>
                <p><strong>Email:</strong> @passenger?.Email</p>
                <p><strong>Passport ID:</strong> @passenger?.PassportId</p>
                <small>
                    <a asp-controller="Passenger" asp-action="Edit" asp-route-id="@passenger?.Id">
                        Edit profile
                    </a>
                </small>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">Select Your Class</div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <input type="hidden" name="flightNumber" value="@flight?.FlightNumber" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Seat Class</label>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <input type="radio" class="btn-check" name="classType" id="economy" value="Economy" checked />
                                <label class="btn btn-outline-primary w-100 p-3" for="economy">
                                    <strong>Economy</strong><br />
                                    <span class="text-success fs-5">$@flight?.Price.ToString("F2")</span>
                                </label>
                            </div>
                            <div class="col-md-4">
                                <input type="radio" class="btn-check" name="classType" id="business" value="Business" />
                                <label class="btn btn-outline-primary w-100 p-3" for="business">
                                    <strong>Business</strong><br />
                                    <span class="text-success fs-5">$@((flight?.Price * 2)?.ToString("F2"))</span>
                                </label>
                            </div>
                            <div class="col-md-4">
                                <input type="radio" class="btn-check" name="classType" id="first" value="First" />
                                <label class="btn btn-outline-primary w-100 p-3" for="first">
                                    <strong>First Class</strong><br />
                                    <span class="text-success fs-5">$@((flight?.Price * 3.5m)?.ToString("F2"))</span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success btn-lg flex-grow-1">
                            ✅ Confirm Reservation
                        </button>
                        <a asp-controller="Flight" asp-action="Details" asp-route-id="@flight?.FlightNumber"
                           class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
