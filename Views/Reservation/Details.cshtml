@model FlightManagementSystem.Models.Reservation
@{
    ViewData["Title"] = $"Reservation #{Model.Id}";
}

<h2>🎫 Reservation #@Model.Id</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-dark text-white">Flight Details</div>
            <div class="card-body">
                <p><strong>Flight:</strong> @Model.FlightId</p>
                <p><strong>Route:</strong> @Model.Flight?.Source → @Model.Flight?.Destination</p>
                <p><strong>Departure:</strong> @Model.Flight?.DepartureTime.ToString("dddd, dd MMM yyyy HH:mm")</p>
                <p><strong>Arrival:</strong> @Model.Flight?.ArrivalTime.ToString("dddd, dd MMM yyyy HH:mm")</p>
                <p><strong>Aircraft:</strong> @Model.Flight?.AircraftType</p>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-header bg-secondary text-white">Passenger</div>
            <div class="card-body">
                <p><strong>Name:</strong> @Model.Passenger?.FullName</p>
                <p><strong>Email:</strong> @Model.Passenger?.Email</p>
                <p><strong>Phone:</strong> @Model.Passenger?.Phone</p>
                <p><strong>Passport ID:</strong> @Model.Passenger?.PassportId</p>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-primary text-white">Booking Info</div>
            <div class="card-body">
                <p><strong>Class:</strong> @Model.ClassType</p>
                <p><strong>Booked on:</strong> @Model.Date.ToString("dd MMM yyyy HH:mm")</p>
                <p><strong>Status:</strong>
                    <span class="badge @(Model.Status == "Confirmed" ? "bg-success" : "bg-secondary")">
                        @Model.Status
                    </span>
                </p>
                @if (Model.Ticket != null)
                {
                    <p><strong>Seat:</strong> @Model.Ticket.SeatNumber</p>
                    <p><strong>Ticket Issued:</strong> @Model.Ticket.IssueDate.ToString("dd MMM yyyy")</p>
                }
            </div>
        </div>

        @if (Model.Payment != null)
        {
            <div class="card shadow-sm mb-3 border-success">
                <div class="card-header bg-success text-white">✅ Payment Confirmed</div>
                <div class="card-body">
                    <p><strong>Amount:</strong> $@Model.Payment.Amount.ToString("F2")</p>
                    <p><strong>Method:</strong> @Model.Payment.Method</p>
                    <p><strong>Date:</strong> @Model.Payment.Date.ToString("dd MMM yyyy HH:mm")</p>
                    <p><strong>Transaction ID:</strong> <code>@Model.Payment.TransactionId</code></p>
                </div>
            </div>
        }
        else if (Model.Status == "Confirmed")
        {
            <div class="alert alert-warning">
                <strong>Payment pending.</strong>
                <a asp-controller="Payment" asp-action="Payment" asp-route-reservationId="@Model.Id">
                    Complete payment →
                </a>
            </div>
        }

        <div class="d-flex gap-2 mt-2">
            <a asp-action="Index" class="btn btn-outline-secondary">← My Reservations</a>
            @if (Model.Status == "Confirmed")
            {
                <a asp-action="Cancel" asp-route-id="@Model.Id" class="btn btn-outline-danger">Cancel</a>
            }
        </div>
    </div>
</div>
