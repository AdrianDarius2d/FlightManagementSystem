@model FlightManagementSystem.Models.Passenger
@{
    ViewData["Title"] = "Create Passenger Profile";
    var returnUrl = ViewBag.ReturnUrl as string;
}

<h2>👤 Complete Your Passenger Profile</h2>
<p class="text-muted">Please fill in your details to proceed with booking.</p>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="FirstName" class="form-label fw-semibold"></label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="LastName" class="form-label fw-semibold"></label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold"></label>
                <input asp-for="Email" class="form-control" type="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Phone" class="form-label fw-semibold"></label>
                <input asp-for="Phone" class="form-control" type="tel" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="form-label fw-semibold"></label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PassportId" class="form-label fw-semibold"></label>
                <input asp-for="PassportId" class="form-control" placeholder="e.g. P123456789" />
                <span asp-validation-for="PassportId" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Save Profile</button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Skip for now</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
