@model FlightManagementSystem.Models.Passenger
@{
    ViewData["Title"] = "Delete Passenger";
}

<div class="alert alert-danger">
    <h4>⚠️ Delete Passenger @Model.FullName?</h4>
    <p>This will permanently remove this passenger and all associated records.</p>
</div>

<div class="card shadow-sm" style="max-width: 450px">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-5">Full Name</dt>
            <dd class="col-sm-7">@Model.FullName</dd>
            <dt class="col-sm-5">Email</dt>
            <dd class="col-sm-7">@Model.Email</dd>
            <dt class="col-sm-5">Passport ID</dt>
            <dd class="col-sm-7">@Model.PassportId</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3 d-flex gap-2">
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
