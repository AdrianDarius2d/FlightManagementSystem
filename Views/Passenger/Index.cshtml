@model IEnumerable<FlightManagementSystem.Models.Passenger>
@{
    ViewData["Title"] = "Passenger Management";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>👤 Passenger Management</h2>
    <a asp-action="Create" class="btn btn-success">+ Add Passenger</a>
</div>

<form method="get" class="mb-3">
    <div class="input-group" style="max-width: 400px">
        <input type="text" name="search" class="form-control" placeholder="Search by name, email, passport..."
               value="@ViewBag.Search" />
        <button type="submit" class="btn btn-outline-primary">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No passengers found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Passport ID</th>
                    <th>Bookings</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td>@p.FullName</td>
                        <td>@p.Email</td>
                        <td>@p.Phone</td>
                        <td><code>@p.PassportId</code></td>
                        <td><span class="badge bg-primary">@p.Reservations?.Count(r => r.Status == "Confirmed")</span></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary me-1">View</a>
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
