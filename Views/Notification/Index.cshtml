@model IEnumerable<FlightManagementSystem.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
    var unread = Model.Count(n => !n.IsRead);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>
        🔔 Notifications
        @if (unread > 0)
        {
            <span class="badge bg-danger ms-1">@unread new</span>
        }
    </h2>
    @if (Model.Any(n => !n.IsRead))
    {
        <form asp-action="MarkAllRead" method="post">
            <button type="submit" class="btn btn-outline-secondary btn-sm">Mark all as read</button>
        </form>
    }
</div>
<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">You have no notifications.</div>
}
else
{
    <div class="list-group shadow-sm">
        @foreach (var n in Model)
        {
            <div class="list-group-item list-group-item-action @(!n.IsRead ? "list-group-item-light" : "")">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="d-flex gap-2">
                        <span class="fs-5">
                            @(n.Type switch {
                                "Confirmation" => "✅",
                                "Cancellation" => "❌",
                                "FlightChange" => "⚠️",
                                "System" => "📢",
                                _ => "🔔"
                            })
                        </span>
                        <div>
                            <p class="mb-1 @(!n.IsRead ? "fw-bold" : "")">@n.Message</p>
                            <small class="text-muted">@n.CreatedAt.ToString("dd MMM yyyy HH:mm")</small>
                            <span class="badge @(n.Type == "Confirmation" ? "bg-success" : n.Type == "Cancellation" ? "bg-danger" : n.Type == "System" ? "bg-warning text-dark" : "bg-secondary") ms-2">
                                @n.Type
                            </span>
                        </div>
                    </div>
                    @if (!n.IsRead)
                    {
                        <form asp-action="MarkRead" method="post" class="ms-2">
                            <input type="hidden" name="id" value="@n.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Dismiss</button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>
}
