@model IEnumerable<FlightManagementSystem.Models.ActivityLog>
@{
    ViewData["Title"] = "Activity & Audit Logs";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📋 Activity &amp; Audit Logs</h2>
    <small class="text-muted">REQ-63, REQ-80 | @Model.Count() entries</small>
</div>

<!-- Filter Form -->
<form method="get" class="card p-3 mb-4 shadow-sm">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label fw-semibold">User (email or ID)</label>
            <input type="text" name="userId" class="form-control" value="@ViewBag.FilterUserId" placeholder="Search by email or ID" />
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold">Action</label>
            <select name="action" class="form-select">
                <option value="">All Actions</option>
                @foreach (var a in new[] { "Login","LoginFailed","Logout","Create","Update","Delete","Cancel","Payment","Backup","Restore","RoleChange","PasswordReset","AccountLocked","ConfigChange" })
                {
                    <option value="@a" selected="@(ViewBag.FilterAction == a)">@a</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold">From</label>
            <input type="date" name="from" class="form-control" value="@ViewBag.FilterFrom" />
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold">To</label>
            <input type="date" name="to" class="form-control" value="@ViewBag.FilterTo" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary me-2">Filter</button>
            <a asp-action="ActivityLogs" class="btn btn-outline-secondary">Clear</a>
        </div>
    </div>
</form>

<div class="table-responsive shadow-sm">
    <table class="table table-hover table-sm align-middle">
        <thead class="table-dark">
            <tr>
                <th>Timestamp</th>
                <th>User</th>
                <th>Action</th>
                <th>Description</th>
                <th>Entity</th>
                <th>IP</th>
                <th>Result</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr class="@(!log.IsSuccess ? "table-danger" : "")">
                    <td><small>@log.Timestamp.ToString("dd MMM yyyy HH:mm:ss")</small></td>
                    <td><small>@(log.UserEmail ?? log.UserId ?? "System")</small></td>
                    <td>
                        <span class="badge @(log.Action == "Login" ? "bg-success" : log.Action == "LoginFailed" ? "bg-danger" : log.Action == "Delete" || log.Action == "Cancel" ? "bg-warning text-dark" : log.Action == "ConfigChange" || log.Action == "RoleChange" ? "bg-info text-dark" : "bg-secondary")">
                            @log.Action
                        </span>
                    </td>
                    <td><small>@log.Description</small></td>
                    <td><small class="text-muted">@(log.EntityType != null ? $"{log.EntityType} #{log.EntityId}" : "-")</small></td>
                    <td><small class="text-muted">@(log.IpAddress ?? "-")</small></td>
                    <td>
                        @if (log.IsSuccess)
                        {
                            <span class="text-success">✔</span>
                        }
                        else
                        {
                            <span class="text-danger">✘</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No log entries match the current filters.</div>
}

<div class="mt-3 d-flex gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary">← Dashboard</a>
    <button onclick="window.print()" class="btn btn-outline-dark">🖨️ Print Log</button>
</div>
