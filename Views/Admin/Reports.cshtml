@model IEnumerable<FlightManagementSystem.Models.Reservation>
@{
    ViewData["Title"] = "Reports";
    var flightStats = ViewBag.FlightStats as IEnumerable<dynamic>;
    var revenueByMethod = ViewBag.RevenueByMethod as IEnumerable<dynamic>;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📊 Reports</h2>
    <small class="text-muted">Generated: @DateTime.Now.ToString("dd MMM yyyy HH:mm")</small>
</div>
<hr />

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h4 class="text-success fw-bold">$@((ViewBag.TotalRevenue as decimal? ?? 0).ToString("F2"))</h4>
                <p class="text-muted mb-0">Total Revenue</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h4 class="fw-bold">@Model.Count(r => r.Status == "Confirmed")</h4>
                <p class="text-muted mb-0">Active Reservations</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h4 class="text-warning fw-bold">@Model.Count(r => r.Status == "Cancelled")</h4>
                <p class="text-muted mb-0">Cancellations</p>
            </div>
        </div>
    </div>
</div>

<!-- REQ-25: Flight Report -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-dark text-white">
        ✈️ Flight Load Report
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Flight</th>
                        <th>Route</th>
                        <th>Departure</th>
                        <th>Booked</th>
                        <th>Capacity</th>
                        <th>Load Factor</th>
                        <th>Revenue</th>
                    </tr>
                </thead>
                <tbody>
                    @if (flightStats != null)
                    {
                        @foreach (var f in flightStats)
                        {
                            var load = f.Capacity > 0 ? (int)(((double)f.Booked / (double)f.Capacity) * 100) : 0;
                            <tr>
                                <td><strong>@f.FlightNumber</strong></td>
                                <td>@f.Source → @f.Destination</td>
                                <td><small>@((DateTime)f.DepartureTime).ToString("dd MMM yyyy HH:mm")</small></td>
                                <td>@f.Booked</td>
                                <td>@f.Capacity</td>
                                <td>
                                    <div class="progress" style="height: 20px; min-width: 80px">
                                        <div class="progress-bar @(load >= 80 ? "bg-danger" : load >= 50 ? "bg-warning" : "bg-success")"
                                             style="width: @load%">@load%</div>
                                    </div>
                                </td>
                                <td class="text-success">$@((decimal)f.Revenue).ToString("F2")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Revenue by Payment Method -->
<div class="row g-3">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">💳 Revenue by Payment Method</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Method</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (revenueByMethod != null)
                        {
                            @foreach (var item in revenueByMethod)
                            {
                                <tr>
                                    <td>@item.Method</td>
                                    <td class="text-success fw-bold">$@((decimal)item.Total).ToString("F2")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">📋 Class Distribution</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Class</th>
                            <th>Bookings</th>
                            <th>% of Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var total = Model.Count(r => r.Status == "Confirmed");
                            foreach (var cls in new[] { "Economy", "Business", "First" })
                            {
                                var count = Model.Count(r => r.ClassType == cls && r.Status == "Confirmed");
                                var pct = total > 0 ? (int)((double)count / total * 100) : 0;
                                <tr>
                                    <td>@cls</td>
                                    <td>@count</td>
                                    <td>
                                        <div class="progress" style="height: 16px">
                                            <div class="progress-bar bg-primary" style="width: @pct%">@pct%</div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">← Dashboard</a>
    <button onclick="window.print()" class="btn btn-outline-dark ms-2">🖨️ Print Report</button>
</div>
