@{
    ViewData["Title"] = "System Health Report";
    var latestBackup = ViewBag.LatestBackup as FlightManagementSystem.Models.BackupRecord;
    var maintenanceMode = (bool)ViewBag.MaintenanceMode;
    var errorCount = (int)ViewBag.UnacknowledgedErrors;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🩺 System Health Report</h2>
    <small class="text-muted">REQ-73 | Generated: @DateTime.Now.ToString("dd MMM yyyy HH:mm:ss")</small>
</div>

<!-- Overall health status banner -->
@{
    var isHealthy = errorCount == 0 && !maintenanceMode && latestBackup != null;
}
<div class="alert @(isHealthy ? "alert-success" : "alert-warning") mb-4">
    <h5 class="mb-0">
        @if (isHealthy)
        {
            <span>✅ System Status: <strong>Operational</strong></span>
        }
        else
        {
            <span>⚠️ System Status: <strong>Attention Required</strong></span>
            <ul class="mt-2 mb-0">
                @if (errorCount > 0) { <li>@errorCount unacknowledged error(s) in the error log.</li> }
                @if (maintenanceMode) { <li>Maintenance mode is currently ENABLED.</li> }
                @if (latestBackup == null) { <li>No successful database backup has been recorded.</li> }
            </ul>
        }
    </h5>
</div>

<!-- Metrics grid -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-1">👤</div>
                <h3 class="fw-bold">@ViewBag.TotalUsers</h3>
                <p class="text-muted mb-0">Registered Users</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-1">✈️</div>
                <h3 class="fw-bold">@ViewBag.TotalFlights</h3>
                <p class="text-muted mb-0">Total Flights</p>
                <small class="text-muted">@ViewBag.ScheduledFlights scheduled</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-1">🎫</div>
                <h3 class="fw-bold">@ViewBag.TotalReservations</h3>
                <p class="text-muted mb-0">Total Reservations</p>
                <small class="text-muted">@ViewBag.ConfirmedReservations confirmed</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-1">💰</div>
                <h3 class="fw-bold">$@((ViewBag.TotalRevenue as decimal? ?? 0).ToString("N0"))</h3>
                <p class="text-muted mb-0">Total Revenue</p>
                <small class="text-muted">@ViewBag.TotalPayments transactions</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Backup status -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100 @(latestBackup == null ? "border-danger" : "border-success")">
            <div class="card-header bg-dark text-white">🗄️ Backup Status (REQ-54 to REQ-61)</div>
            <div class="card-body">
                @if (latestBackup != null)
                {
                    <p><strong>Last backup:</strong> @latestBackup.FileName</p>
                    <p><strong>Completed:</strong> @latestBackup.CompletedAt?.ToString("dd MMM yyyy HH:mm")</p>
                    <p><strong>Size:</strong> @((latestBackup.FileSizeBytes / 1024.0).ToString("F1")) KB</p>
                    <p><strong>Integrity:</strong>
                        <span class="@(latestBackup.IntegrityVerified ? "text-success" : "text-warning")">
                            @(latestBackup.IntegrityVerified ? "✔ Verified" : "⚠ Not yet verified")
                        </span>
                    </p>
                }
                else
                {
                    <div class="alert alert-danger mb-0">No backups recorded. Create a backup immediately.</div>
                }
                <a asp-action="Backup" class="btn btn-outline-primary btn-sm mt-2">Manage Backups</a>
            </div>
        </div>
    </div>

    <!-- Error log summary -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100 @(errorCount > 0 ? "border-danger" : "border-success")">
            <div class="card-header bg-dark text-white">🚨 Error Log Summary (REQ-68, REQ-69)</div>
            <div class="card-body">
                @if (errorCount == 0)
                {
                    <p class="text-success fw-bold">✅ No unacknowledged errors.</p>
                }
                else
                {
                    <p class="text-danger fw-bold">⚠ @errorCount unacknowledged error(s) require review.</p>
                }
                <p><strong>Maintenance mode:</strong>
                    <span class="badge @(maintenanceMode ? "bg-warning text-dark" : "bg-success")">
                        @(maintenanceMode ? "ENABLED" : "Disabled")
                    </span>
                </p>
                <div class="d-flex gap-2">
                    <a asp-action="ErrorLogs" class="btn btn-outline-danger btn-sm">View Error Logs</a>
                    <form asp-action="ToggleMaintenanceMode" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm @(maintenanceMode ? "btn-success" : "btn-warning")">
                            @(maintenanceMode ? "Disable Maintenance" : "Enable Maintenance")
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- System settings summary (REQ-65) -->
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">⚙️ Current Configuration (REQ-65, REQ-72)</div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr><th>Setting</th><th>Value</th><th>Category</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in ViewBag.Settings as IEnumerable<FlightManagementSystem.Models.SystemSetting> ?? new List<FlightManagementSystem.Models.SystemSetting>())
                            {
                                <tr>
                                    <td>@s.DisplayName</td>
                                    <td>
                                        @if (s.InputType == "boolean")
                                        {
                                            <span class="badge @(s.Value == "true" ? "bg-success" : "bg-secondary")">
                                                @(s.Value == "true" ? "Enabled" : "Disabled")
                                            </span>
                                        }
                                        else
                                        {
                                            @s.Value
                                        }
                                    </td>
                                    <td><small class="text-muted">@s.Category</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <a asp-action="Settings" class="btn btn-outline-secondary btn-sm mt-2">Edit Settings</a>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary">← Dashboard</a>
    <button onclick="window.print()" class="btn btn-outline-dark">🖨️ Print Report</button>
</div>
